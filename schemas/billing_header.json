{
  "$id": "https://example.com/schemas/billing_header.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BillingHeader",
  "type": "object",
  "properties": {
    "billing_id": {"type": "string"},
    "issue_date": {"type": "string", "format": "date"},
    "period_from": {"type": "string", "format": "date"},
    "period_to": {"type": "string", "format": "date"},
    "customer_id": {"type": "string"},
    "contract_id": {"type": "string"},
    "account_id": {"type": "string"},
    "supply_number": {"type": "string"},
    "tariff_code": {"type": "string"},
    "total_amount": {"type": "number"},
    "currency": {"type": "string"}
  },
  "required": ["billing_id","issue_date","period_from","period_to","customer_id","total_amount"]
}

