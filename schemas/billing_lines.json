{
  "$id": "https://example.com/schemas/billing_lines.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BillingLines",
  "type": "object",
  "properties": {
    "line_id": {"type": "string"},
    "billing_id": {"type": "string"},
    "charge_type": {"type": "string", "enum": ["energy","regulated","taxes","other"]},
    "description": {"type": "string"},
    "quantity_kwh": {"type": ["number","null"]},
    "unit_price": {"type": ["number","null"]},
    "amount": {"type": "number"},
    "unit": {"type": "string"}
  },
  "required": ["line_id","billing_id","charge_type","amount"]
}

